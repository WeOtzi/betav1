# ============================================
# WE ÖTZI - ENVIRONMENT VARIABLES EXAMPLE
# Copiar a .env y rellenar con valores reales
# ============================================

# --- Servidor ---
PORT=4545
CORS_ALLOWED_ORIGINS=http://localhost:4545

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=quotation-references

# --- Google ---
GEMINI_API_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_SERVICE_ACCOUNT=

# --- n8n (legacy email webhooks, being phased out in favor of BillionMail) ---
N8N_WEBHOOK_URL=
N8N_DRIVE_FOLDER_ID=

# --- BillionMail (self-hosted mail server, replaces n8n for transactional emails) ---
# See docs/plans/2026-04-28-billionmail-migration.md for context.
# API key is generated from the BillionMail panel: Settings -> API.
BILLIONMAIL_API_URL=https://bm.weotzi.com
BILLIONMAIL_API_KEY=
BILLIONMAIL_DEFAULT_SENDER=noreply@weotzi.com
BILLIONMAIL_TIMEOUT_MS=15000

# --- Currency normalization (n8n daily cron) ---
# Shared secret used by the n8n cron workflow to call
# /api/admin/currencies/bulk-update and /api/admin/currencies/refresh-now.
# If left empty, server.js auto-generates and persists a token in .env on startup.
# Configure the resulting value as a header `X-Cron-Token` in the n8n workflow.
CRON_API_TOKEN=

# --- EmailJS ---
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=

# --- App ---
WHATSAPP_NUMBER=+541127015926
PRESET_PASSWORD=OtziArtist2025
DEMO_MODE=false

# ============================================
# SUPPORT CHAT AGENT (OpenAI GPT + handoff humano)
# ============================================
# Requerido para que el chat de soporte con IA funcione.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Activa/desactiva globalmente el widget y los endpoints /api/support-chat/*
SUPPORT_CHAT_ENABLED=true
# Tope de tokens por respuesta del bot (default razonable: 800)
SUPPORT_CHAT_MAX_TOKENS=800
# Cuántos intentos fallidos antes de que el bot escale solo a humano
SUPPORT_CHAT_ESCALATE_AFTER=3
